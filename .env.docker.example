# Mailwave — Docker Compose environment template.
#
# 1. Copy to .env:  copy .env.docker.example .env
# 2. Replace every value marked "changeme" with a real secret.
# 3. docker compose up -d --build
#
# Secrets live in .env (gitignored). Never commit real secrets.
# Internal hostnames ("postgres", "redis") are resolvable only inside the
# compose network — do not use them when running Mailwave outside Docker.

# PostgreSQL connection string. The host "postgres" matches the compose
# service name. Change "changeme" to a strong password before first boot.
DATABASE_URL=postgresql://mailwave:changeme@postgres:5432/mailwave?schema=public

# Must match the password embedded in DATABASE_URL above. The in-compose
# postgres service defaults to "changeme" when unset (see docker-compose.yml),
# so you only NEED to set this if you changed the password in DATABASE_URL.
# POSTGRES_PASSWORD=changeme
# POSTGRES_USER=mailwave
# POSTGRES_DB=mailwave

# Secret key for signing Auth.js sessions.
# Generate with:  openssl rand -base64 32
AUTH_SECRET="changeme-generate-with-openssl-rand-base64-32"

# Base URL of the app. Use the host port mapped in docker-compose.yml.
NEXTAUTH_URL="http://localhost:3001"

# Local application port (must match the port published for the `app` service).
PORT=3001

# 32+ character key used to encrypt sensitive data at rest (SMTP passwords,
# API keys, OAuth tokens).
# Generate with:  openssl rand -hex 16
# WARNING: must be at least 32 characters; known placeholders are rejected.
# WARNING: changing this value makes all previously encrypted data unrecoverable
# unless you run `npm run rotate-key` with OLD_ENCRYPTION_KEY set to the previous value.
ENCRYPTION_KEY="changeme-generate-with-openssl-rand-hex-16"

# Redis connection URL, used by BullMQ. The host "redis" matches the compose
# service name.
REDIS_URL="redis://redis:6379"

# App version displayed in the sidebar footer.
NEXT_PUBLIC_APP_VERSION="1.0.0"

# Demo user password for `npm run seed` (dev/test only).
# Seed REFUSES to run when NODE_ENV=production. To seed inside Docker:
#   docker compose run --rm -e NODE_ENV=development app npm run seed
SEED_DEMO_PASSWORD="password123"
