# Mailwave — Docker Compose environment template (unified).
#
# Works for both local Docker (docker-compose.local.yml) and Easypanel
# (docker-compose.yml). Both compose files build DATABASE_URL from the
# POSTGRES_* variables below via ${VAR} substitution, so you do NOT need
# to set DATABASE_URL here.
#
# Local Docker:
#   1. copy .env.docker.example .env
#   2. Replace every CHANGE_ME value with a real secret.
#   3. docker compose -f docker-compose.local.yml up -d --build
#
# Easypanel:
#   Set these as project environment variables in the Easypanel UI.
#   Compose file: docker-compose.yml
#
# Secrets live in .env (gitignored). Never commit real secrets.

# --- PostgreSQL (both compose files build DATABASE_URL from these) ---
POSTGRES_PASSWORD="CHANGE_ME_STRONG_PASSWORD"
POSTGRES_USER="mailwave"
POSTGRES_DB="mailwave"

# --- Auth ---
# Generate with:  openssl rand -base64 32
AUTH_SECRET="CHANGE_ME_openssl_rand_base64_32"

# Base URL of the app.
# Local Docker:  http://localhost:3001
# Easypanel:    https://your-domain.com
AUTH_URL="http://localhost:3001"

AUTH_TRUST_HOST="true"

# --- Encryption (32+ chars) ---
# 32+ character key used to encrypt sensitive data at rest (SMTP passwords,
# API keys, OAuth tokens).
# Generate with:  openssl rand -hex 16
# WARNING: must be at least 32 characters; known placeholders are rejected.
# WARNING: changing this value makes all previously encrypted data unrecoverable
# unless you run `npm run rotate-key` with OLD_ENCRYPTION_KEY set to the previous value.
ENCRYPTION_KEY="CHANGE_ME_openssl_rand_hex_16"

# --- Redis ---
# The host "redis" matches the compose service name.
REDIS_URL="redis://redis:6379"

# --- App ---
NEXT_PUBLIC_APP_VERSION="1.0.0"

# --- Seed (local dev only; seed REFUSES to run when NODE_ENV=production) ---
# To seed inside Docker:
#   docker compose -f docker-compose.local.yml run --rm -e NODE_ENV=development app npm run seed
SEED_DEMO_PASSWORD="password123"

# --- Easypanel / Traefik (only needed for docker-compose.yml) ---
# APP_DOMAIN is the public hostname (no https://) used by Traefik routing labels.
# TRAEFIK_* override the defaults; safe to leave as-is for standard Easypanel setups.
APP_DOMAIN="mailwave.example.com"
TRAEFIK_NETWORK="easypanel"
TRAEFIK_CERT_RESOLVER="letsencrypt"
TRAEFIK_HTTP_MIDDLEWARE="redirect-to-https"
