# Production override for docker-compose.yml.
#
# Copy .env.docker.prod.example to .env and fill in real secrets BEFORE
# deploying. Real secrets must NEVER live in this file.
#
# Apply with:
#   docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d

# PostgreSQL connection string. Use a strong password (NOT "changeme").
DATABASE_URL=postgresql://mailwave:REPLACE_WITH_STRONG_PASSWORD@postgres:5432/mailwave?schema=public

# Secret key for signing Auth.js sessions.
# Generate with:  openssl rand -base64 32
AUTH_SECRET="REPLACE_WITH_openssl_rand_base64_32"

# Public base URL of the app — must be the real HTTPS domain fronted by the
# reverse proxy (Caddy/Traefik). The app container itself only listens on
# PORT (3001) inside the compose network.
NEXTAUTH_URL="https://mailwave.example.com"

# Internal application port (not published to the host in prod).
PORT=3001

# 32+ character key used to encrypt sensitive data at rest.
# Generate with:  openssl rand -hex 16
# WARNING: rotation requires `npm run rotate-key` with OLD_ENCRYPTION_KEY.
ENCRYPTION_KEY="REPLACE_WITH_openssl_rand_hex_16"

# Redis connection URL (internal hostname).
REDIS_URL="redis://redis:6379"

NEXT_PUBLIC_APP_VERSION="1.0.0"
