# Mailwave on Easypanel Compose
#
# Create one service of type "Compose" from this repository and set:
# - Compose file: docker-compose.yml
# - Environment: the variables below

APP_DOMAIN="mailwave.example.com"
NEXTAUTH_URL="https://mailwave.example.com"

POSTGRES_PASSWORD="CHANGE_ME_STRONG_PASSWORD"
POSTGRES_USER="mailwave"
POSTGRES_DB="mailwave"

AUTH_SECRET="CHANGE_ME_BASE64_32"
AUTH_TRUST_HOST="true"

# 32+ chars. Rotating this without re-encryption breaks stored secrets.
ENCRYPTION_KEY="CHANGE_ME_32_PLUS_CHARS"

REDIS_URL="redis://redis:6379"
NEXT_PUBLIC_APP_VERSION="1.0.0"

# Optional Easypanel / Traefik overrides.
TRAEFIK_NETWORK="easypanel"
TRAEFIK_CERT_RESOLVER="letsencrypt"
TRAEFIK_HTTP_MIDDLEWARE="redirect-to-https"
